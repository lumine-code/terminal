{
  "atom-workspace": {
    "ctrl-`": "terminal:focus",
    "ctrl-~ n": "terminal:open",
    "ctrl-~ up": "terminal:open-split-up",
    "ctrl-~ down": "terminal:open-split-down",
    "ctrl-~ left": "terminal:open-split-left",
    "ctrl-~ right": "terminal:open-split-right",
    "ctrl-~ b": "terminal:open-split-bottom-dock",
    "ctrl-~ l": "terminal:open-split-left-dock",
    "ctrl-~ r": "terminal:open-split-right-dock",
    "ctrl-~ x": "terminal:run-selected-text",
    "ctrl-~ i": "terminal:insert-selected-text"
  },
  "terminal-view": {
    "ctrl-l": "terminal:clear",
    "cmdorctrl-f": "terminal:find",
    "cmdorctrl-e": "terminal:set-selection-as-find-pattern",
    "ctrl-`": "terminal:unfocus"
  },
  ".platform-darwin terminal-view": {
    "cmd-alt-k": "terminal:clear",
    "cmd-g": "terminal:find-next",
    "cmd-shift-g": "terminal:find-previous"
  },
  ".platform-win32 terminal-view, .platform-linux terminal-view": {
    "f3": "terminal:find-next",
    "shift-f3": "terminal:find-previous"
  },
  ".terminal-find-palette atom-text-editor": {
    "cmdorctrl-f": "terminal:find"
  },
  ".platform-darwin .terminal-find-palette atom-text-editor": {
    "cmd-g": "terminal:find-next",
    "cmd-shift-g": "terminal:find-previous"
  },
  ".platform-win32 .terminal-find-palette atom-text-editor, .platform-linux .terminal-find-palette atom-text-editor": {
    "f3": "terminal:find-next",
    "shift-f3": "terminal:find-previous"
  }
}
