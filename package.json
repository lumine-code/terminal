{
  "name": "terminal",
  "main": "./lib/terminal",
  "version": "1.0.0",
  "description": "A terminal emulator built into Lumine.",
  "keywords": [
    "terminal",
    "term",
    "xterm",
    "shell",
    "tty",
    "pty",
    "bash",
    "sh",
    "powershell",
    "cmd"
  ],
  "files": [
    "lib",
    "keymaps",
    "menus",
    "shell-integration",
    "styles"
  ],
  "repository": "https://github.com/lumine-code/terminal",
  "bugs": {
    "url": "https://github.com/lumine-code/terminal/issues"
  },
  "homepage": "https://github.com/lumine-code/terminal#readme",
  "author": "lumine-code",
  "license": "MIT",
  "engines": {
    "atom": "*",
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "activationHooks": [
    "core:loaded-shell-environment"
  ],
  "deserializers": {
    "TerminalModel": "deserializeTerminalModel"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "@lumine-code/etch": "https://github.com/lumine-code/etch.git#f790460144d0e4ea12d1d5f3394a9543c0bb7f6c",
    "fs-extra": "^11.3.2",
    "ndjson": "^2.0.0",
    "node-pty": "^1.1.0",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^18.2.2",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "temp": "^0.9.4"
  },
  "providedServices": {
    "terminal": {
      "description": "Run commands and open terminals.",
      "versions": {
        "2.0.0": "provideTerminalService"
      }
    }
  }
}
