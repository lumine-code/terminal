{
  "name": "terminal",
  "main": "./lib/terminal",
  "version": "1.0.0",
  "description": "A terminal emulator built into Lumine.",
  "keywords": [
    "terminal",
    "term",
    "xterm",
    "shell",
    "tty",
    "pty",
    "bash",
    "sh",
    "powershell",
    "cmd"
  ],
  "repository": "https://github.com/lumine-code/terminal",
  "bugs": {
    "url": "https://github.com/lumine-code/terminal/issues"
  },
  "homepage": "https://github.com/lumine-code/terminal#readme",
  "author": "lumine-code",
  "license": "MIT",
  "engines": {
    "atom": "*",
    "node": ">=20"
  },
  "activationHooks": [
    "core:loaded-shell-environment"
  ],
  "deserializers": {
    "TerminalModel": "deserializeTerminalModel"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-ligatures": "^0.10.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "etch": "^0.14.1",
    "fs-extra": "^11.3.2",
    "ndjson": "^2.0.0",
    "node-pty": "^1.1.0",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "temp": "^0.9.4"
  },
  "providedServices": {
    "terminal": {
      "description": "Run commands and open terminals.",
      "versions": {
        "2.0.0": "provideTerminalService"
      }
    }
  }
}
